msgstr "Требуется корректное целое число."

#: fields.py:932 fields.py:969 fields.py:1005 fields.py:1366
#, python-brace-format
msgid "Ensure this value is less than or equal to {max_value}."
msgstr "Убедитесь, что значение не превышает {max_value}."

#: fields.py:933 fields.py:970 fields.py:1006 fields.py:1367
#, python-brace-format
msgid "Ensure this value is greater than or equal to {min_value}."
msgstr "Убедитесь, что значение не меньше {min_value}."

#: fields.py:934 fields.py:971 fields.py:1010
msgid "String value too large."
msgstr "Строковое значение слишком большое."

#: fields.py:968 fields.py:1004
msgid "A valid number is required."
msgstr "Требуется корректное число."

#: fields.py:1007
#, python-brace-format
msgid "Ensure that there are no more than {max_digits} digits in total."
msgstr "Убедитесь, что общее количество цифр не превышает {max_digits}."

